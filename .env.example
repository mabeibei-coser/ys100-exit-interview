# ---- 复制本文件为 .env.local（开发）或 .env（生产）后填写 ----

# iron-session 加密口令，必须 >= 32 个字符的随机串
SESSION_PASSWORD=please_change_me_to_a_random_32+_char_string

# 回访员共享团队口令（发给全组，回访员登录用）
TEAM_PASSWORD=yongsheng2026

# 生产环境置 true（https 下 cookie 才带 secure）；本机 dev 留空或 false
COOKIE_SECURE=false

# SQLite 数据库路径（默认 ./data/exit-interview.db）。
# 绝不要放在坚果云/OneDrive 同步目录，WAL 文件会损坏。
# DB_PATH=/var/lib/exit-interview/exit-interview.db

# 子路径（默认 /d100）。本机想用根路径可设为空。
# BASE_PATH=/d100

# 计划回访总人数（用于"访谈完成率"）；在岗总人数可选，用于真实离职率
PLANNED_TOTAL=100
# HEADCOUNT_TOTAL=700
